---
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';
import type { PartnerSpotlight as Props } from '~/types';

const {
  title = '',
  subtitle = '',
  tagline = '',
  partners = [],
  callToAction,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      partners &&
        partners.map(({ partnerName, logo, industry, partnerSince, websiteUrl, tagline: partnerTagline, description, featured, stats }) => (
          <div class:list={[
            'flex flex-col rounded-xl shadow-lg dark:shadow-none dark:border dark:border-slate-600 overflow-hidden intersect-once motion-safe:md:intersect:animate-fade motion-safe:md:opacity-0 intersect-quarter',
            featured ? 'ring-2 ring-primary' : '',
          ]}>
            {/* Logo / header area */}
            <div class="flex items-center gap-4 p-6 bg-white dark:bg-slate-800">
              {logo?.src && (
                <div class="h-14 w-14 flex-shrink-0 rounded-md overflow-hidden border border-slate-100 dark:border-slate-700">
                  <Image
                    class="h-14 w-14 object-contain"
                    width={56}
                    height={56}
                    widths={[56, 112]}
                    layout="fixed"
                    src={logo.src}
                    alt={logo.alt ?? partnerName ?? 'Partner logo'}
                  />
                </div>
              )}
              <div>
                {partnerName && <h3 class="text-lg font-bold text-heading leading-tight">{partnerName}</h3>}
                {industry && <p class="text-xs text-muted uppercase tracking-wide mt-0.5">{industry}</p>}
                {partnerSince && (
                  <p class="text-xs text-muted mt-0.5">Partner since {new Date(partnerSince).getFullYear()}</p>
                )}
              </div>
              {featured && (
                <span class="ml-auto text-xs font-semibold bg-primary text-white rounded-full px-2.5 py-0.5 whitespace-nowrap">
                  Featured
                </span>
              )}
            </div>

            {/* Body */}
            <div class="flex flex-col flex-auto p-6 bg-slate-50 dark:bg-slate-900">
              {partnerTagline && (
                <p class="text-base font-semibold text-heading mb-2">{partnerTagline}</p>
              )}
              {description && (
                <p class="text-muted text-sm leading-relaxed flex-auto">{description}</p>
              )}

              {/* Stats row */}
              {stats && stats.length > 0 && (
                <div class="flex gap-4 mt-5 pt-4 border-t border-slate-200 dark:border-slate-700">
                  {stats.map(({ amount, label }) => (
                    <div class="text-center flex-1">
                      {amount && <p class="text-xl font-bold text-primary">{amount}</p>}
                      {label && <p class="text-xs text-muted">{label}</p>}
                    </div>
                  ))}
                </div>
              )}

              {/* Link */}
              {websiteUrl && (
                <a
                  href={websiteUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 text-sm font-medium text-primary hover:underline inline-flex items-center gap-1"
                >
                  Visit site
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 3h7m0 0v7m0-7L10 14M5 5H3a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-2" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))
    }
  </div>

  {
    callToAction && (
      <div class="flex justify-center mx-auto w-fit mt-8 md:mt-12 font-medium">
        <Button {...callToAction} />
      </div>
    )
  }
</WidgetWrapper>

