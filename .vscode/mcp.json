{
  "mcpServers": {
    "sanity": {
      "command": "npx",
      "args": ["-y", "@sanity/mcp-server"],
      "env": {
        "SANITY_PROJECT_ID": "your_project_id",
        "SANITY_DATASET": "production",
        "SANITY_TOKEN": "your_write_token"
      }
    },
    "azure-ai-foundry": {
      "command": "npx",
      "args": ["-y", "@azure/mcp-server-foundry"],
      "env": {
        "AZURE_FOUNDRY_ENDPOINT": "your_endpoint",
        "AZURE_SUBSCRIPTION_ID": "your_sub_id"
      }
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "supabase-mcp-server"],
      "env": {
        "SUPABASE_URL": "your_url",
        "SUPABASE_SERVICE_ROLE_KEY": "your_key"
      }
    }
  }
}
