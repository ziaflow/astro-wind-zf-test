# Email Configuration
# Choose email backend: 'web3forms' or 'nodemailer'
EMAIL_BACKEND=web3forms

# Web3Forms Configuration (if using EMAIL_BACKEND=web3forms)
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here

# Nodemailer SMTP Configuration (if using EMAIL_BACKEND=nodemailer)
# Also used by the `lead-nurture-email` Supabase Edge Function (set these via `supabase secrets set`)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@ziaflow.com
SMTP_TO=info@ziaflow.com
# Internal address that receives new-lead notifications (used by lead-nurture-email edge function)
MAIL_TO=sales@ziaflow.com

# Supabase Configuration
# Used by the leads-table trigger. Set these as Postgres config parameters in your Supabase project:
#   ALTER DATABASE postgres SET app.supabase_url = 'https://your-project.supabase.co';
#   ALTER DATABASE postgres SET app.supabase_anon_key = 'your-anon-key';
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Form Configuration
CONTACT_FORM_SUBJECT=New Contact Request from ZiaFlow Website
CONTACT_FORM_FROM_NAME=ZiaFlow Contact Form

# Chatbot Configuration
PUBLIC_BOT_SECRET=

# IndexNow API Key for SEO
INDEXNOW_KEY=23ae16e3343c4a4fae1d800cbc6d31f6

