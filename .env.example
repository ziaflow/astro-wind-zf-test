# Email Configuration
# Choose email backend: 'web3forms' or 'nodemailer'
EMAIL_BACKEND=web3forms

# Web3Forms Configuration (if using EMAIL_BACKEND=web3forms)
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here

# Nodemailer SMTP Configuration (if using EMAIL_BACKEND=nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@ziaflow.com
SMTP_TO=info@ziaflow.com

# Form Configuration
CONTACT_FORM_SUBJECT=New Contact Request from ZiaFlow Website
CONTACT_FORM_FROM_NAME=ZiaFlow Contact Form

# Chatbot Configuration
PUBLIC_BOT_SECRET=

# IndexNow API Key for SEO
INDEXNOW_KEY=23ae16e3343c4a4fae1d800cbc6d31f6

# Supabase Configuration
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Azure Communication Services (used by the lead-nurture-email Supabase Edge Function)
# Set these as Supabase secrets: supabase secrets set ACS_ENDPOINT=...
ACS_ENDPOINT=https://<resource-name>.communication.azure.com
ACS_ACCESS_KEY=your-acs-access-key-here
ACS_SENDER_ADDRESS=DoNotReply@<domain>.azurecomm.net
NURTURE_RECIPIENT=info@ziaflow.com

