# Email Configuration
# Choose email backend: 'web3forms' or 'nodemailer'
EMAIL_BACKEND=web3forms

# Web3Forms Configuration (if using EMAIL_BACKEND=web3forms)
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here

# Nodemailer SMTP Configuration (if using EMAIL_BACKEND=nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@ziaflow.com
SMTP_TO=info@ziaflow.com

# Form Configuration
CONTACT_FORM_SUBJECT=New Contact Request from ZiaFlow Website
CONTACT_FORM_FROM_NAME=ZiaFlow Contact Form

# Chatbot Configuration
PUBLIC_BOT_SECRET=

# IndexNow API Key for SEO
INDEXNOW_KEY=23ae16e3343c4a4fae1d800cbc6d31f6

# ---------------------------------------------------------------------------
# Supabase Configuration
# ---------------------------------------------------------------------------
# Project URL and public anon key (safe to expose in browser)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Service-role key — server-side only, NEVER expose to the browser.
# Used to invoke Supabase Edge Functions from the API route.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---------------------------------------------------------------------------
# Azure Email Communication Services
# (used by the lead-nurture-email Supabase Edge Function)
# ---------------------------------------------------------------------------
# Full connection string from Azure Portal → Communication Services → Keys
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://<resource>.communication.azure.com/;accesskey=<base64-key>

# Verified sender address from your Azure Email Communication domain
AZURE_EMAIL_SENDER=DoNotReply@<domain>.azurecomm.net

# Internal team inbox that receives lead-alert emails
INTERNAL_NOTIFY_EMAIL=info@ziaflow.com

# Origin allowed for CORS in the Edge Function (defaults to https://ziaflow.com)
SITE_URL=https://ziaflow.com

